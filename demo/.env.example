# === LLM Provider for the Orchestrator Agent ===
# Choose one: "vertex_ai", "azure_openai", "openai", or "anthropic"
LLM_PROVIDER=vertex_ai
LLM_MODEL=gemini-2.5-pro

# === Google Cloud / Vertex AI ===
# Authenticate first: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Tell SLIDERS to use Vertex AI instead of Azure OpenAI
SLIDERS_LLM_PROVIDER=vertex_ai

# === EnergyPlus ===
# Path to the Energy+.idd file in your EnergyPlus installation
EPLUS_IDD_PATH=C:/EnergyPlusV25-1-0/Energy+.idd

# === SLIDERS Knowledge Base ===
# Path to EnergyPlus Engineering Reference (markdown or plain text)
# Leave empty to run without knowledge-augmented mode
EP_DOCS_PATH=

# === Alternative LLM providers (uncomment if needed) ===
# AZURE_OPENAI_API_KEY=
# AZARE_URL_ENDPOINT=https://<your-resource>.openai.azure.com/
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
